# ──────────────────────────────────────────
# .gitignore — QLDangKyHP
# Node.js + Express + SQL Server
# ──────────────────────────────────────────

# ── Node.js ────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ── Biến môi trường (TUYỆT ĐỐI không commit) ─
.env
.env.local
.env.development
.env.production

# ── Log files ─────────────────────────────
logs/
*.log

# ── Build / cache ──────────────────────────
dist/
build/
.cache/
.parcel-cache/

# ── SQL Server backup ──────────────────────
*.bak
*.mdf
*.ldf

# ── Hệ điều hành ──────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# ── Editor / IDE ───────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Tài liệu tạm ──────────────────────────
*.tmp
*.temp
~$*